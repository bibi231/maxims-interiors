# ============================================================
# MAXIMS INTERIORS — FRONTEND (Vite) ENVIRONMENT
# Copy to .env and fill in. Only VITE_* vars are exposed to the browser,
# so ONLY ever put public values here. The API/server secrets live in
# server/.env (see server/.env.example).
# ============================================================

# Base URL of the Express API
VITE_API_URL=http://localhost:4000

# App
VITE_APP_NAME=Maxims Interiors & Home Goods

# Payments — PUBLIC keys only (default provider used by the storefront)
VITE_PAYMENT_PROVIDER=squad
VITE_SQUAD_PUBLIC_KEY=
VITE_PAYSTACK_PUBLIC_KEY=
