# ============================================================
# MAXIMS INTERIORS — FRONTEND ENVIRONMENT (Vite)
# Only VITE_* values are exposed to the browser — public only.
# ============================================================

# API base URL.
# - Production on Vercel: LEAVE BLANK (frontend + API share the same domain).
# - Local dev: set to your local API, e.g. http://localhost:4000
VITE_API_URL=

# Payments — PUBLIC keys only
VITE_PAYMENT_PROVIDER=squad
VITE_SQUAD_PUBLIC_KEY=
VITE_PAYSTACK_PUBLIC_KEY=

# SupportAI chat widget (from your SupportAI account). Leave blank to hide it.
VITE_SUPPORTAI_WIDGET_URL=https://supportai.com.ng/widget.js
VITE_SUPPORTAI_SITE_KEY=
